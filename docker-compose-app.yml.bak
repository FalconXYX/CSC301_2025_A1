version: "3.8"

services:
  nginx-lb:
    image: nginx:alpine
    container_name: csc301_api_gateway
    ports:
      - "4001:4001"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    depends_on:
      - user-service
      - product-service
      - order-service

  user-service:
    build:
      context: ./UserService
    volumes:
      - ./docker-config.json:/app/config.json:ro
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m -XX:+UseG1GC
      - SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT:-5432}/csc301_db
    deploy:
      replicas: 3
    restart: on-failure

  product-service:
    build:
      context: ./ProductService
    volumes:
      - ./docker-config.json:/app/config.json:ro
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m -XX:+UseG1GC
      - SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT:-5432}/csc301_db
    deploy:
      replicas: 3
    restart: on-failure

  order-service:
    build:
      context: ./OrderService
    volumes:
      - ./docker-config.json:/app/config.json:ro
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m -XX:+UseG1GC
      - SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT:-5432}/csc301_db
    deploy:
      replicas: 3
    restart: on-failure

  iscs:
    build:
      context: ./ISCS
    volumes:
      - ./docker-config.json:/app/config.json:ro
    environment:
      - ISCS_LISTEN_IP=0.0.0.0
      - USER_SERVICE_IP=user-service
      - USER_SERVICE_PORT=14001
      - PRODUCT_SERVICE_IP=product-service
      - PRODUCT_SERVICE_PORT=15000
    deploy:
      replicas: 3
    depends_on:
      - user-service
      - product-service
    restart: on-failure
